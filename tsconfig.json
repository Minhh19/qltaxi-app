{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    "baseUrl": ".",   // 🔥 THÊM CÁI NÀY

    "paths": {
      "@/*": ["./*"]
    },

    "types": ["expo-router"]  // 🔥 THÊM CÁI NÀY
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}